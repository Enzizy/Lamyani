rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    function allowedUserKeys() {
      return [
        'firstName',
        'lastName',
        'fullName',
        'birthDate',
        'email',
        'mobileNumber',
        'emailUpdates',
        'points',
        'createdAt',
        'lastLoginAt'
      ];
    }

    function validUserProfile(data) {
      return data.keys().hasOnly(allowedUserKeys()) &&
        data.keys().hasAll(allowedUserKeys()) &&
        data.firstName is string &&
        data.firstName.size() > 0 &&
        data.firstName.size() <= 50 &&
        data.lastName is string &&
        data.lastName.size() > 0 &&
        data.lastName.size() <= 50 &&
        data.fullName is string &&
        data.fullName.size() > 0 &&
        data.fullName.size() <= 120 &&
        data.birthDate is timestamp &&
        data.email is string &&
        data.mobileNumber is string &&
        data.mobileNumber.size() >= 10 &&
        data.mobileNumber.size() <= 15 &&
        data.emailUpdates is bool &&
        data.points is int &&
        data.createdAt is timestamp &&
        data.lastLoginAt is timestamp;
    }

    function allowedProductKeys() {
      return [
        'id',
        'name',
        'category',
        'description',
        'imageUrl',
        'prepTime',
        'rating',
        'status',
        'branches',
        'updatedAt',
        'variants'
      ];
    }

    function validProduct(data) {
      return data.keys().hasOnly(allowedProductKeys()) &&
        data.name is string &&
        data.name.size() > 0 &&
        data.category is string &&
        data.category.size() > 0 &&
        data.description is string &&
        data.imageUrl is string &&
        data.prepTime is string &&
        data.rating is number &&
        data.status is string &&
        data.status in ['active', 'draft', 'featured'] &&
        data.branches is list &&
        data.variants is list &&
        data.variants.size() > 0 &&
        data.updatedAt is timestamp;
    }

    function allowedBranchKeys() {
      return [
        'id',
        'name',
        'address',
        'region',
        'status',
        'hours',
        'latitude',
        'longitude',
        'manager',
        'productCount',
        'nextPromo'
      ];
    }

    function validBranch(data) {
      return data.keys().hasOnly(allowedBranchKeys()) &&
        data.name is string &&
        data.address is string &&
        data.region is string &&
        data.status is string &&
        data.status in ['open', 'closed', 'opening-soon'] &&
        data.hours is string &&
        data.latitude is number &&
        data.longitude is number;
    }

    function allowedPromoKeys() {
      return [
        'id',
        'title',
        'subtitle',
        'status',
        'audience',
        'appliesTo',
        'schedule',
        'imageUrl',
        'updatedAt'
      ];
    }

    function validPromo(data) {
      return data.keys().hasOnly(allowedPromoKeys()) &&
        data.title is string &&
        data.title.size() > 0 &&
        data.subtitle is string &&
        data.status is string &&
        data.status in ['live', 'scheduled', 'draft'] &&
        data.audience is string &&
        data.appliesTo is string &&
        data.schedule is string &&
        (!('imageUrl' in data) || data.imageUrl is string) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function allowedOrderKeys() {
      return [
        'customerId',
        'customerName',
        'branchId',
        'branchName',
        'items',
        'itemsSummary',
        'subtotal',
        'deliveryFee',
        'total',
        'status',
        'placedAt'
      ];
    }

    function validOrder(data) {
      return data.keys().hasOnly(allowedOrderKeys()) &&
        data.customerId is string &&
        data.branchId is string &&
        data.items is list &&
        data.subtotal is number &&
        data.deliveryFee is number &&
        data.total is number &&
        data.status is string &&
        data.status in ['preparing', 'ready', 'delivered', 'cancelled'] &&
        data.placedAt is timestamp;
    }

    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if isOwner(userId) &&
        validUserProfile(request.resource.data) &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.points == 0;

      allow read: if isOwner(userId) || isAdmin();

      allow update: if isOwner(userId) &&
        validUserProfile(request.resource.data) &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.points == resource.data.points &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'firstName',
          'lastName',
          'fullName',
          'birthDate',
          'mobileNumber',
          'emailUpdates',
          'lastLoginAt'
        ]);

      allow update: if isAdmin() &&
        validUserProfile(request.resource.data) &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && validProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if true;
      allow create, update: if isAdmin() && validBranch(request.resource.data);
      allow delete: if isAdmin();
    }

    match /promos/{promoId} {
      allow read: if true;
      allow create, update: if isAdmin() && validPromo(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if signedIn() &&
        validOrder(request.resource.data) &&
        request.resource.data.customerId == request.auth.uid;

      allow read: if isAdmin() ||
        (signedIn() && resource.data.customerId == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
